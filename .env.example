NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE=your-publishable-value

# Supabase Auth (BYG-70, magic link) – konfigurera i Dashboard:
# Authentication → Providers → Email (aktivera, Confirm email ON för magic link)
# Authentication → Email Templates → Magic Link (kontrollera avsändare)
# Utan Custom SMTP skickar Supabase bara till e-postadresser i organisationens Team.
# Produktion: Authentication → SMTP Settings → Resend (https://resend.com/docs/send-with-supabase-smtp)
# Gratis inbyggd SMTP: låg kvot/tim + rate limit vid många test.
# Authentication → URL Configuration:
#   Site URL: https://byggello.se
#   Redirect URLs:
#     https://byggello.se/auth/callback
#     http://localhost:3000/auth/callback
#     https://*.vercel.app/auth/callback
# (utan ?next= – redirect efter login sparas i cookie)

# Valfritt: används av /api/subscribe om satt (kringgår RLS). Annars används publishable enligt migration.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude) – endast server, t.ex. /api/analyse
ANTHROPIC_API_KEY=

# Bekräftelsemejl från server (Resend). Nyckeln exponeras aldrig i frontend.
RESEND_API_KEY=
# Avsändare, t.ex. Byggello <nyheter@dinverifieradedomän.se> (kräver verifierad domän i Resend).
RESEND_FROM=

# Kanonisk URL (sitemap, Open Graph, auth). Produktion: https://byggello.se
# Lämna tom på Vercel Preview om magic link ska använda preview-URL (VERCEL_URL).
# Lokalt: http://localhost:3000 (eller din dev-port)
NEXT_PUBLIC_SITE_URL=https://byggello.se

# Google Search Console: meta google-site-verification finns i app/layout.tsx (metadata.verification).

# Sanity (hitta projectId under https://www.sanity.io/manage )
NEXT_PUBLIC_SANITY_PROJECT_ID=ditt-projekt-id
NEXT_PUBLIC_SANITY_DATASET=production

# Google Maps Platform (Places Autocomplete på /analys). Nyckeln exponeras till
# klienten – måste ha HTTP-referrer-restriktioner och bara Maps JavaScript API
# + Places API aktiverat i Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
