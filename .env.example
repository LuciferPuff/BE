NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE=your-publishable-value

# Valfritt: används av /api/subscribe om satt (kringgår RLS). Annars används publishable enligt migration.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude) – endast server, t.ex. /api/analyse
ANTHROPIC_API_KEY=

# Bekräftelsemejl från server (Resend). Nyckeln exponeras aldrig i frontend.
RESEND_API_KEY=
# Avsändare, t.ex. Byggello <nyheter@dinverifieradedomän.se> (kräver verifierad domän i Resend).
RESEND_FROM=

# Kanonisk URL (sitemap, Open Graph, canonical). Produktion: https://byggello.se
NEXT_PUBLIC_SITE_URL=https://byggello.se

# Google Search Console: meta google-site-verification finns i app/layout.tsx (metadata.verification).

# Sanity (hitta projectId under https://www.sanity.io/manage )
NEXT_PUBLIC_SANITY_PROJECT_ID=ditt-projekt-id
NEXT_PUBLIC_SANITY_DATASET=production

# Google Maps Platform (Places Autocomplete på /analys). Nyckeln exponeras till
# klienten – måste ha HTTP-referrer-restriktioner och bara Maps JavaScript API
# + Places API aktiverat i Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
